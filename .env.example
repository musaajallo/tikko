# =============================================================================
# tikko — environment template
# Copy to .env and fill in. Same file shape works for LAN and VPS deployments.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment mode
# -----------------------------------------------------------------------------
# lan   = running on an office LAN; devices reachable on private IPs;
#         ADMS push endpoint bound to internal interface; relaxed TLS.
# cloud = running on a VPS; devices reachable via public IP or VPN;
#         ADMS push endpoint internet-facing; TLS required.
TIKKO_DEPLOY_MODE=lan

# Public base URL of the api (used by web, mobile, and devices for push).
TIKKO_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
TIKKO_DATABASE_URL=postgresql+psycopg://tikko:tikko@localhost:5432/tikko

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
TIKKO_JWT_SECRET=change-me-to-a-long-random-string
TIKKO_JWT_ACCESS_TTL_MIN=15
TIKKO_JWT_REFRESH_TTL_DAYS=30

# -----------------------------------------------------------------------------
# Device polling defaults (overridable per device)
# -----------------------------------------------------------------------------
TIKKO_DEFAULT_POLL_INTERVAL_SEC=60
TIKKO_ZK_CONNECT_TIMEOUT_SEC=10

# -----------------------------------------------------------------------------
# CORS — comma-separated origins allowed to call the api
# -----------------------------------------------------------------------------
TIKKO_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
TIKKO_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Email (Resend — https://resend.com)
# -----------------------------------------------------------------------------
# Leave empty in dev — the api logs intended sends and skips the network call.
# For prod, get an API key from resend.com and set the From address to a
# verified domain.
TIKKO_RESEND_API_KEY=
TIKKO_FROM_EMAIL=no-reply@tikko.local
