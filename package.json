{
  "name": "tikko",
  "private": true,
  "version": "0.0.0",
  "description": "Custom ZKTeco attendance terminal management platform — single deployable for LAN or VPS.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "cd apps/api && uv run fastapi dev src/tikko/main.py",
    "dev:web": "pnpm --filter @tikko/web dev",
    "dev:mobile": "pnpm --filter @tikko/mobile start",
    "dev:turbo": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && pnpm test:api",
    "test:api": "cd apps/api && uv run pytest",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
